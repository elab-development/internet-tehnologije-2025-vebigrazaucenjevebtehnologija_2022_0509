# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# C extensions
*.so

# Distribution / packaging
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# uv and virtual environment
# Typically named .venv or venv
.venv/
venv/
env/
.env/

# IDE specific files (optional, adjust as needed)
.idea/  # For PyCharm/IntelliJ
.vscode/ # For VS Code
*.swp   # For Vim
*.swo

# OS generated files
.DS_Store # macOS
Thumbs.db # Windows

# Testing and coverage
.coverage
.mypy_cache/ # Mypy static analysis cache
.pytest_cache/ # Pytest cache
htmlcov/
.nox/

# Logs and databases
*.log
*.sqlite
*.sqlite3
test.db # Example database file
